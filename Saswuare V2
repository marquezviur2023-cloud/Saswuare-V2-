-- --- BOTÓN DE TELEPORT ---
local posDestino = nil
local tpBtn = Instance.new("TextButton", MainFrame)
tpBtn.Size = UDim2.new(0.9, 0, 0, 55)
tpBtn.Position = UDim2.new(0.05, 0, 0, 60)
tpBtn.Text = "📍 MARCAR BASE"
tpBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
tpBtn.TextColor3 = Color3.new(1, 1, 1)
tpBtn.Font = Enum.Font.GothamBold
tpBtn.TextSize = 11

tpBtn.MouseButton1Click:Connect(function()
    if not posDestino then
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            posDestino = LocalPlayer.Character.HumanoidRootPart.Position
            tpBtn.Text = "🚀 IR A MI BASE"
            tpBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
        end
    else
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(posDestino + Vector3.new(0, 3, 0))
        end
    end
end)

-- Resetear con Click Derecho o Doble Click
tpBtn.MouseButton2Click:Connect(function()
    posDestino = nil
    tpBtn.Text = "📍 MARCAR BASE"
    tpBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
end)

